// =============================================
//  Subash — Prisma Schema
//  Database: SQLite
//  Run: npx prisma generate && npx prisma db push
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================
//  Enums
// =============================================

enum Role {
  SUPER_ADMIN
  MODERATOR
  SELLER
  DECANTER
  STANDARD
  BRAND_PARTNER
}

enum AuthProvider {
  GOOGLE
  FACEBOOK
  CREDENTIALS
}

enum Season {
  SPRING
  SUMMER
  AUTUMN
  WINTER
  ALL_SEASON
}

enum TimeOfDay {
  DAY
  NIGHT
  BOTH
  MORNING
  EVENING
  ANYTIME
}

enum ReviewStatus {
  APPROVED
  PENDING
  SPAM
}

// =============================================
//  User
// =============================================

model User {
  id            String       @id @default(cuid())
  name          String?
  username      String?      @unique  // unique handle e.g. @scentlord — set by user from profile settings
  email         String?      @unique
  emailVerified DateTime?
  phone         String?      @unique
  phoneVerified Boolean      @default(false)
  image         String?  // renamed from avatarUrl — required by @auth/prisma-adapter
  bio           String?
  password      String?  // nullable — OAuth users have no password; bcryptjs hash for manual auth
  role            String       @default("STANDARD")
  isBanned        Boolean      @default(false)
  banReason       String?
  review_count    Int          @default(0)
  reputationScore Int          @default(0)   // Reputation Engine: +2 per review, +1 per HAVE item
  authProvider    String       @default("CREDENTIALS")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  accounts        Account[]
  sessions        Session[]
  reviews         Review[]
  deals           Deal[]
  dupeVotes       DupeVote[]
  wardrobeItems   WardrobeItem[]
  fragramPosts    FragramPost[]
  reviewUpvotes   ReviewUpvote[]
  decantListings  DecantListing[] @relation("UserDecants")
  notifications   Notification[]
  followers       Follows[]       @relation("UserFollowing")
  following       Follows[]       @relation("UserFollowers")
  suggestedDupes  PerfumeDupe[]
  brandClaims     BrandClaim[]
  comments        Comment[]
  wearingStatus   WearingStatus?

  @@index([reputationScore])  // smart review sort: high-rep authors first
  @@index([review_count])     // fast leaderboard sorts
  @@map("users")
}

// =============================================
//  NextAuth.js Required Tables
// =============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================
//  Perfume
// =============================================

model Perfume {
  id           String   @id @default(cuid())
  name         String
  brand        String
  image_url    String?
  top_notes    String   @default("[]")
  heart_notes  String   @default("[]")
  base_notes   String   @default("[]")
  transparentImageUrl String?
  release_year Int?
  perfumer     String?
  description  String?
  gender       String?
  accords      String   @default("[]")
  slug         String   @unique
  scraped      Boolean  @default(false)
  searchCount  Int      @default(0)
  source_url   String?              // Original Fragrantica URL
  country      String?              // Brand country of origin (e.g. "France")
  rating_value Float?               // Fragrantica average rating (e.g. 3.07)
  rating_count Int?                 // Number of ratings on Fragrantica
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  reviews        Review[]
  deals          Deal[]
  dupeOriginal   DupeVote[]      @relation("OriginalPerfume")
  dupeClone      DupeVote[]      @relation("ClonePerfume")
  wardrobeItems  WardrobeItem[]
  dupesForThis   PerfumeDupe[]   @relation("TargetDupes")
  isDupeOf       PerfumeDupe[]   @relation("IsDupeOf")
  fragramPosts   FragramPost[]
  potdEntries    PerfumeOfTheDay[]
  decantListings DecantListing[]
  searchStats    PerfumeSearchStat[]
  creator        Creator?        @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId      String?
  wearingStatuses WearingStatus[]

  @@index([name, brand])
  @@index([name])
  @@index([slug])
  @@index([brand])           // groupBy brand in sidebar trending-brands query
  @@index([release_year])    // fallback climate-picks orderBy
  @@index([creatorId])       // creator portfolio lookups
  @@index([searchCount(sort: Desc)]) // Crucial for the Trending feed
  @@map("perfumes")
}

// =============================================
//  Wearing Status (Currently Wearing)
// =============================================

model WearingStatus {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  perfumeId  String?
  perfume    Perfume? @relation(fields: [perfumeId], references: [id])
  customName String?
  timeTag    String?  // 'day', 'night', 'all'
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// =============================================
//  PerfumeSearchStat
//  Aggregated search clicks per perfume per day, used for
//  "Trending This Week" and other time-windowed trends.
// =============================================

model PerfumeSearchStat {
  id        String   @id @default(cuid())
  perfume   Perfume  @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  perfumeId String
  date      DateTime
  count     Int      @default(0)

  @@unique([perfumeId, date])
  @@index([date])
  @@index([perfumeId])
}

// =============================================
//  Review
// =============================================

model Review {
  id              String     @id @default(cuid())
  userId          String
  perfumeId       String
  text            String
  overall_rating  Float        // 1.0 – 10.0
  longevity_score  Int          // 1 – 10
  sillage_score    Int          // 1 – 10
  projection_score Int?         // 1 – 10 (optional for older reviews)
  intensity_score  Int?         // 1 – 10 (optional for older reviews)
  status           String       @default("APPROVED")
  time_tags       String        @default("[]")
  weather_tags    String        @default("[]")    // stringified array of weather tags
  upvote_count    Int          @default(0)
  genderLeaning   Int?
  occasion        String?
  valueRating     Int?
  blindBuySafe    Boolean?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  perfume Perfume          @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  upvotes ReviewUpvote[]
  title String?
  imageUrl String?
  comments Comment[]

  @@unique([userId, perfumeId])
  @@index([userId])
  @@index([perfumeId])
  @@index([createdAt(sort: Desc)])
  // Weather tag index removed for SQLite
  @@map("reviews")
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReviewUpvote {
  id       String @id @default(cuid())
  userId   String
  reviewId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@map("review_upvotes")
}

// =============================================
//  Shop (Verified Boutique)
// =============================================

model Shop {
  id                 String   @id @default(cuid())
  name               String
  website            String?
  address            String?
  latitude           Float?
  longitude          Float?
  isVerified         Boolean  @default(false)
  description        String?
  imageUrl           String?
  createdAt          DateTime @default(now())

  deals Deal[]

  @@index([isVerified])
  @@map("shops")
}

// =============================================
//  Deal (Live Price Tracker)
// =============================================

model Deal {
  id                 String   @id @default(cuid())
  perfumeId          String
  sellerId           String
  shopId             String?  // optional link to a verified boutique
  price              Int      // price in BDT (Taka)
  url                String?  // direct buy link
  discountPercentage Int?     // optional discount %
  link               String?
  is_active          Boolean  @default(true)
  is_featured        Boolean  @default(false)
  last_updated       DateTime @default(now()) @updatedAt

  perfume Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  seller  User    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  shop    Shop?   @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([perfumeId, is_active])
  @@index([shopId])
  @@map("deals")
}

// =============================================
//  DupeVote (Dupe / Clone Finder)
// =============================================

model DupeVote {
  id                 String   @id @default(cuid())
  originalPerfumeId  String
  clonePerfumeId     String
  upvotes            Int      @default(0)
  downvotes          Int      @default(0)
  submittedBy        String
  createdAt          DateTime @default(now())

  // match_score is computed: upvotes / (upvotes + downvotes) * 100
  original  Perfume @relation("OriginalPerfume", fields: [originalPerfumeId], references: [id], onDelete: Cascade)
  clone     Perfume @relation("ClonePerfume",    fields: [clonePerfumeId],    references: [id], onDelete: Cascade)
  submitter User    @relation(fields: [submittedBy], references: [id], onDelete: Cascade)

  @@unique([originalPerfumeId, clonePerfumeId])
  @@index([originalPerfumeId])
  @@map("dupe_votes")
}

// =============================================
//  Personal Wardrobe
// =============================================

// shelf values: "HAVE" | "HAD" | "WANT" | "SIGNATURE"
model WardrobeItem {
  id        String   @id @default(cuid())
  shelf     String   // HAVE | HAD | WANT | SIGNATURE
  userId    String
  perfumeId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  perfume Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)

  @@unique([userId, perfumeId])
  @@index([userId])
  @@map("wardrobe_items")
}

// =============================================
//  Fragram (SOTD Feed)
// =============================================

model FragramPost {
  id        String   @id @default(cuid())
  imageUrl  String   // Path to the uploaded image
  caption   String?  // Optional text
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  perfumeId String?  // Optional: Tag the perfume they are wearing
  perfume   Perfume? @relation(fields: [perfumeId], references: [id])
  
  likes     Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@index([perfumeId])
}

  // Removed FragramLike

// =============================================
//  Notification
// =============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String   // The user receiving the notification
  type      String   // e.g., "LIKE", "FOLLOW", "DUPE_UPVOTE"
  message   String
  link      String?  // Where to send them when they click it
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// =============================================
//  Perfume of the Day
// =============================================

model PerfumeOfTheDay {
  id        String   @id @default(cuid())
  perfumeId String
  date      DateTime @unique // one entry per calendar day
  note      String?  // editorial note from admin
  createdAt DateTime @default(now())

  perfume Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)

  @@map("perfume_of_the_day")
}

// =============================================
//  Decant Listing (P2P WhatsApp Marketplace)
// =============================================

model DecantListing {
  id              String   @id @default(cuid())
  price_5ml       Int?                          // price in BDT, nullable if not offered
  price_10ml      Int?                          // price in BDT, nullable if not offered
  batch_code      String                        // e.g. "B24Q3" for authenticity tracing
  proof_image_url String                        // uploaded photo proving authenticity
  status          String   @default("AVAILABLE") // AVAILABLE | SOLD | PAUSED

  perfumeId String
  perfume   Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)

  sellerId String
  seller   User   @relation("UserDecants", fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([perfumeId, status])
  @@index([sellerId])
  @@map("decant_listings")
}

// =============================================
//  Creator (Master Perfumer)
// =============================================

model Creator {
  id       String    @id @default(cuid())
  name     String    @unique
  bio      String?
  image    String?   // optional avatar / portrait URL
  website  String?   // optional personal site
  perfumes Perfume[]

  createdAt DateTime @default(now())

  @@index([name])
  @@map("creators")
}

// =============================================
//  Feature Toggle (Kill Switch)
// =============================================

model FeatureToggle {
  id        String   @id @default(cuid())
  key       String   @unique
  isEnabled Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("feature_toggles")
}

// =============================================
//  Environment Variables (encrypted storage)
// =============================================

model EnvVariable {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // AES-256-GCM encrypted
  iv        String   // Initialization vector for decryption
  tag       String   // GCM auth tag
  masked    Boolean  @default(true) // Show as *** in UI
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("env_variables")
}

// =============================================
//  Audit Log (Enterprise Security)
// =============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   // Store as string to avoid strict cascading issues, but links to User
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================
//  B2B Monetization (Claims)
// =============================================

model BrandClaim {
  id            String   @id @default(cuid())
  userId        String
  brandName     String
  officialEmail String
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED
  message       String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("brand_claims")
}

model PerfumeDupe {
  id              String   @id @default(cuid())
  targetPerfumeId String   // The perfume being viewed
  dupePerfumeId   String   // The suggested alternative

  // Relations back to Perfume
  targetPerfume   Perfume  @relation("TargetDupes", fields: [targetPerfumeId], references: [id], onDelete: Cascade)
  dupePerfume     Perfume  @relation("IsDupeOf", fields: [dupePerfumeId], references: [id], onDelete: Cascade)
  
  votes           Int      @default(1) // Net score (upvotes - downvotes)
  userId          String   // The user who first suggested it
  user            User     @relation(fields: [userId], references: [id])

  createdAt       DateTime @default(now())

  @@unique([targetPerfumeId, dupePerfumeId]) // Prevent duplicate links
  @@index([targetPerfumeId])
}


model Follows {
  followerId  String
  followingId String
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// =============================================
//  Import Job — Background CSV import tracking
// =============================================

model ImportJob {
  id            String   @id @default(cuid())
  filename      String
  status        String   @default("pending") // pending | processing | completed | failed
  totalRows     Int      @default(0)
  processedRows Int      @default(0)
  insertedRows  Int      @default(0)
  skippedRows   Int      @default(0)
  errorRows     Int      @default(0)
  errorLog      String   @default("[]")      // JSON array of error messages
  format        String   @default("auto")     // auto | fra_cleaned | fra_perfumes | generic
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@map("import_jobs")
}

