# =============================================
#  Subash — Environment Variables
#  Copy this file to .env.local and fill in values
#  NEVER commit .env.local to version control
# =============================================

# --- Database (SQLite) ---
# Local dev:
DATABASE_URL="file:./subash.db"
# Docker / CasaOS (override to match the bind-mount path):
# DATABASE_URL="file:/app/data/subash.db"

# --- Auth.js v5 (next-auth v5) ---
# Generate with:  npx auth secret   OR   openssl rand -base64 32
AUTH_SECRET="generate-with: npx auth secret"
# Local dev (Next.js runs on 3000 with `npm run dev`):
AUTH_URL="http://localhost:3000"
# Docker / CasaOS (exposed on 9864):
# AUTH_URL="http://<casaos-ip>:9864"
# Production:
# AUTH_URL="https://subash.com.bd"

# --- Google OAuth ---
# Console: https://console.developers.google.com
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Facebook OAuth ---
# Console: https://developers.facebook.com/apps
# Valid OAuth redirect URI: http://localhost:3000/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# --- Firebase (Phone OTP — Phase 2.2) ---
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# --- OpenWeatherMap ---
OPENWEATHERMAP_API_KEY=""
NEXT_PUBLIC_DEFAULT_CITY="Dhaka"

# --- Site URL ---
NEXT_PUBLIC_SITE_URL="https://subash.rico.bd"

# --- CasaOS / Docker seeding ---
# Set to "true" on FIRST boot to import all ~70k perfumes from the bundled CSV.
# After the import finishes, set to "false" (or remove) so restarts skip it.
SEED_DB="false"

# --- Docker / CasaOS overrides ---
# Host port the app is exposed on (default: 9864)
APP_PORT=9864
# Host directory bind-mounted to /app/data inside the container (holds SQLite file)
DATA_DIR=/DATA/AppData/subash/data
# Prisma Studio port — only needed when running Studio manually inside the container
PRISMA_STUDIO_PORT=5555
